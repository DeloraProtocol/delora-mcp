{
  "name": "@deloraprotocol/mcp",
  "scope": "deloraprotocol",
  "version": "0.1.3",
  "description": "Delora MCP server for cross-chain quotes and tools",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "delora-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "dev:http": "MCP_TRANSPORT=http PORT=3000 tsx src/index.ts",
    "start": "node dist/index.js",
    "start:http": "MCP_TRANSPORT=http node dist/index.js",
    "prepublishOnly": "node -e \"const p=require('./package.json'); const scope=p.scope||'delora'; const prefix='@'+scope+'/'; if(!p.name.startsWith(prefix)) throw new Error('package name must start with '+prefix);\""
  },
  "keywords": [
    "delora",
    "mcp",
    "cross-chain",
    "bridge",
    "defi",
    "quote"
  ],
  "license": "MIT",
  "files": [
    "dist",
    "SKILL.md",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/DeloraProtocol/delora-mcp.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "express": "^5.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.19.9",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
